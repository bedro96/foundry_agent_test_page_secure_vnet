# ============================================================================
# 백엔드 환경 구성
# ============================================================================
# 이 파일은 AI 채팅 포털의 Python FastAPI 백엔드를 구성합니다.
# 시작 시 app/config.py (pydantic-settings)에 의해 dotenv를 통해 로드됩니다.
#
# 보안: 이 파일에는 비밀 정보가 포함되어 있습니다. 버전 관리에 절대 커밋하지 마세요.
#           공개 템플릿은 .env.example을 사용하세요.
# ============================================================================

# ── 애플리케이션 설정 ────────────────────────────────────────────────────
# APP_ENV: 전체 백엔드의 환경 수준 동작을 제어합니다.
#   - "Production" → API 키 인증 미들웨어 활성화, INFO 수준 로깅
#   - "development" → API 키 인증 비활성화, 호출 위치 정보 포함 DEBUG 수준 로깅
#   사용처: config.py, auth.py, logging.py
APP_ENV=Production

# LOG_KEEPALIVE: 헬스체크 엔드포인트 로그 출력 여부.
#   False → /health/live, /health/ready 로그 억제 (안정 운영 시 불필요한 로그 제거)
#   True → 헬스체크 로그 정상 출력
#   사용처: config.py, logging.py, main.py
LOG_KEEPALIVE=False

# BACKEND_API_KEY: 프론트엔드가 x-api-key 헤더로 보내는 공유 비밀키.
#   APP_ENV=Production일 때 필수이며, /api/auth/** 및 /api/mcp/** 를 제외한
#   보호된 /api/** 요청은 유효한 키 없이 거부됩니다.
#   값이 비어 있으면 인증이 비활성화되는 것이 아니라 서버가 503으로 거부합니다.
#   사용처: auth.py (APIKeyAuthMiddleware)
BACKEND_API_KEY=00MS6tR9Lln/RrOQrBMDrWBzBAh9lO8rX7NuvcC6VZ5n0L5t

# JWT_SECRET: JWT 토큰 서명에 사용되는 비밀 키. (Production에서는 안전하게 관리되어야 함)
JWT_SECRET=f6Q9cX2mYJ7bL0uRz5N3e8aVwTgHk4pDs1FjM2xCqZo

# ── Azure AI Foundry / OpenAI 프로젝트 ───────────────────────────────────────
# 이 설정은 채팅 엔드포인트를 구동하는 Azure AI 에이전트를 구성합니다.
# 사용처: agent.py (AzureAIFoundryAgent), agent_framework/base.py

# AZURE_AI_PROJECT_ENDPOINT: Azure AI Projects 리소스의 전체 URL.
#   형식: https://<resource>.services.ai.azure.com/api/projects/<project-name>
#   사용처: agent.py — 에이전트 오케스트레이션을 위해 AIProjectClient에 전달
AZURE_AI_PROJECT_ENDPOINT="https://aiservicestjsy.services.ai.azure.com/api/projects/projecttjsy"

# AZURE_AI_AGENT_NAME: 생성/재사용할 Foundry 프롬프트 에이전트의 표시 이름.
#   사용처: agent.py — 에이전트 조회 및 생성
AZURE_AI_AGENT_NAME="chat-portal-agent"

# AZURE_AI_MODEL: 채팅 완성을 위한 기본 LLM 배포 이름.
#   사용처: config.py (azure_ai_model 필드), agent.py — 모델 선택
AZURE_AI_MODEL="gpt-5.4-nano"


# 이전 API 버전 (롤백 참조용으로 보존):
# AZURE_AI_AIP_VERSION="2024-12-01-preview"

# ── Azure AI 에이전트 동작 ────────────────────────────────────────────────
# AZURE_AI_AGENT_INSTRUCTIONS: Foundry 에이전트에 주입되는 시스템 프롬프트.
#   에이전트의 페르소나, 책임 및 응답 형식을 정의합니다.
#   현재 역할: 공장 이상 감지, 진단 및 조치 권고.
#   사용처: config.py (azure_ai_agent_instructions), agent.py — 에이전트 생성
AZURE_AI_AGENT_INSTRUCTIONS="당신은 공장의 공정을 이상 징후를 감지하고 진단하고 조치를 권고하는 Agent입니다. 최대한 정확하게 진단에 대한 판단 근거를 제시를 하고, 예상되는 원인에 대한 판단 근거도 제시를 해야하고, 필요한 조치를 제안하며, 최선책과 차선책을 제시를 해야합니다. 보고는 timeline별로 방생된 상황을 우선 정의를 해야합니다."

# ── Azure Entra ID (서비스 주체) ──────────────────────────────────────────
# DefaultAzureCredential / ClientSecretCredential에서 사용하는 앱 등록 자격 증명.
# 필요처: agent.py (AI Projects 인증), speech.py (배치 전사 Bearer 토큰)
# 사용처: config.py, agent.py, speech.py — Azure SDK 자격 증명 체인

# AZURE_CLIENT_ID: Entra ID 서비스 주체의 애플리케이션 (클라이언트) ID.
AZURE_CLIENT_ID="49d490c1-6a46-4c81-b346-4095e3767c26"

# AZURE_CLIENT_SECRET: 서비스 주체의 클라이언트 비밀 값.
AZURE_CLIENT_SECRET="xC58Q~GH0afWZ4EdIhDX1wYnzvIzEnc7mS9dMdyl"

# AZURE_TENANT_ID: 서비스 주체가 등록된 디렉터리 (테넌트) ID.
AZURE_TENANT_ID="56f1a052-bd09-41fb-9aeb-b2c206e7e54f"

# ── Bing 그라운딩 검색 ──────────────────────────────────────────────────
# BING_GROUNDING_CONNECTION_NAME: Bing 그라운딩 검색을 위한 Azure AI Project 연결 이름.
#   에이전트가 실시간 웹 데이터로 응답을 그라운딩할 수 있도록 합니다.
#   사용처: config.py, agent.py — BingGroundingTool 구성
BING_GROUNDING_CONNECTION_NAME="groundedbybing3b0lf9"
#
# BROWSER_AUTOMATION_PROJECT_CONNECTION_ID: 브라우저 자동화 도구 테스트용 연결 ID.
#   현재 프로덕션에서는 사용되지 않으며, 개발/테스트 목적으로만 보존됩니다.
#   사용처: config.py (browser_automation_project_connection_id)
BROWSER_AUTOMATION_PROJECT_CONNECTION_ID="browserautomation_f4fc9c"
# ── Azure Speech 서비스 ────────────────────────────────────────────────────
# Azure Speech 배치 전사 API (v3.2)를 통한 음성-텍스트 변환.
# 사용처: speech.py (AzureSpeechTranscriber)

# AZURE_SPEECH_ENDPOINT: Azure AI Services의 Cognitive Services 엔드포인트 URL.
#   형식: https://<resource>.cognitiveservices.azure.com/
#   토큰 발급 (/sts/v1.0/issuetoken) 및 배치 API에 사용됩니다.
#   REST v1 음성 인식은 이 엔드포인트에서 직접 지원되지 않으므로
#   AZURE_SPEECH_REGION과 함께 리전 엔드포인트를 사용합니다.
AZURE_SPEECH_ENDPOINT="https://aiservicestjsy.cognitiveservices.azure.com/"

# AZURE_SPEECH_REGION: Azure Speech 리소스가 배포된 리전 코드.
#   REST v1 음성 인식을 위한 리전 엔드포인트 URL 구성에 사용됩니다.
#   리전 엔드포인트: https://{region}.stt.speech.microsoft.com
#   예: eastus2, koreacentral, westus3
AZURE_SPEECH_REGION=westus3

# AZURE_SPEECH_LANGUAGE: 음성-텍스트 인식의 기본 BCP-47 로케일.
#   예: ko-KR, en-US, ja-JP
#   사용처: speech.py — 배치 전사 로케일 매개변수
AZURE_SPEECH_LANGUAGE=ko-KR

# ── GenAI 텔레메트리 트레이싱 ──────────────────────────────────────────────
# OpenTelemetry 기반의 Azure AI Foundry 에이전트 실행 추적을 위한 설정입니다.
# Application Insights에서 에이전트 호출, LLM 요청/응답, 도구 실행 등의
# 상세 트레이스를 확인할 수 있습니다.

# ENABLE_TELEMETRY: 텔레메트리 전체를 제어하는 최상위 킬 스위치.
#   false → OpenTelemetry 초기화를 완전히 건너뛰고 관련 로그만 비활성 상태로 남깁니다.
ENABLE_TELEMETRY=True

# AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING: GenAI 트레이싱 활성화 여부.
#   true → Azure SDK가 LLM 호출에 대한 OpenTelemetry 스팬을 자동 생성합니다.
#   false → 트레이싱이 비활성화되어 추적 데이터가 수집되지 않습니다.
#   사용처: telemetry.py — 앱 시작 시 os.environ에 설정
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true

# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT: 메시지 내용 캡처 여부.
#   true → 프롬프트, 응답 텍스트 등 실제 메시지 내용이 트레이스에 포함됩니다.
#          디버깅에 유용하지만 민감 정보가 Application Insights에 기록될 수 있습니다.
#   false → 메타데이터만 기록되며 실제 메시지 내용은 포함되지 않습니다.
#   주의: 프로덕션 환경에서는 개인정보 보호를 위해 false로 설정하는 것을 권장합니다.
#   사용처: telemetry.py — 앱 시작 시 os.environ에 설정
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
# OTEL_SERVICE_NAME: 표준 OpenTelemetry 서비스 이름 변수.
#   현재 애플리케이션 코드는 이 값을 직접 읽거나 설정하지 않습니다.
#   필요 시 런타임/플랫폼에서 별도로 주입할 수 있는 참고용 항목입니다.
#OTEL_SERVICE_NAME=lgit-chat-backend

# ── 런타임 / 네트워킹 ────────────────────────────────────────────────────
# REQUEST_TIMEOUT_SECONDS: 아웃바운드 HTTP 요청의 전역 타임아웃 (초 단위).
#   Foundry 에이전트가 여러 반복(MCP 승인, Bing 그라운딩 등)을 수행할 때
#   충분한 시간이 필요합니다. 15초는 너무 짧아 다중 반복 에이전트 실행 시
#   시간 초과가 발생합니다.
#   사용처: config.py (request_timeout_seconds), agent.py
REQUEST_TIMEOUT_SECONDS=60

# BACKEND_PUBLIC_URL: Azure Container Apps에서 이 백엔드의 공개 기본 URL.
#   Azure Speech 배치 작업이 인메모리 볼트 라우트 (/audio/<token>)에서
#   오디오를 다운로드할 수 있도록 필요합니다.
#   사용처: speech.py (_require_backend_url), main.py (오디오 서빙 라우트)
BACKEND_PUBLIC_URL=https://lgit-secure-chat-backend.salmonmeadow-1fede345.westus3.azurecontainerapps.io

# ── MySQL 연결 설정 ───────────────────────────────────────────────────────
# Azure Database for MySQL 유연한 서버 연결.
# 사용처: config.py, database.py (PyMySQL을 통한 SQLAlchemy 엔진), db_models.py

# MYSQL_HOST: Azure MySQL 유연한 서버의 호스트 이름.
#   형식: <server-name>.mysql.database.azure.com
MYSQL_HOST=kukomysql.privatelink.mysql.database.azure.com

# MYSQL_PORT: MySQL 연결을 위한 TCP 포트 (기본값: 3306).
MYSQL_PORT=3306

# MYSQL_DB: 대상 데이터베이스 이름. 테이블은 시작 시 SQLAlchemy를 통해 자동 생성됩니다.
MYSQL_DB=chatdb

# MYSQL_USER: 데이터베이스 로그인 사용자 이름.
MYSQL_USER=azureuser

# MYSQL_PASSWORD: 데이터베이스 로그인 비밀번호.
MYSQL_PASSWORD=Rhrmagml1234

# MYSQL_SSL_MODE: MySQL 연결의 TLS 모드.
#   값: required | preferred | disabled
#   Azure MySQL은 기본적으로 SSL을 강제합니다; "required"는 암호화된 전송을 보장합니다.
#   사용처: database.py (_create_ssl_context)
MYSQL_SSL_MODE=required

# ── MySQL 연결 튜닝 (선택사항) ──────────────────────────────────────────────
# SQLAlchemy / PyMySQL의 세밀한 풀 및 인코딩 설정.
# 사용처: config.py, database.py (get_engine)

# MYSQL_POOL_SIZE: SQLAlchemy 풀의 최대 영구 연결 수.
#   높은 동시성 워크로드에서는 증가시키세요; 기본값 5는 적당한 트래픽에 적합합니다.
MYSQL_POOL_SIZE=5

# MYSQL_CHARSET: PyMySQL 연결 문자열의 문자 집합.
#   utf8mb4는 이모지를 포함한 전체 유니코드를 지원합니다.
MYSQL_CHARSET=utf8mb4

# MYSQL_CONNECT_TIMEOUT: 새 연결 시도가 시간 초과되기까지 대기하는 초 수.
#   사용처: database.py (connect_args["connect_timeout"])
MYSQL_CONNECT_TIMEOUT=10

