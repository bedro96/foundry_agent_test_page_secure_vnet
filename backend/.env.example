# ============================================================================
# 백엔드 환경 구성 (템플릿)
# ============================================================================
# 이 파일은 AI 채팅 포털의 Python FastAPI 백엔드를 위한 환경 변수 템플릿입니다.
# 실제 사용 시 이 파일을 .env로 복사한 후 값을 채워 넣으세요.
#
# 사용법: cp .env.example .env  →  값을 편집
# ============================================================================

# === 애플리케이션 설정 ===

# APP_ENV: 백엔드 실행 환경 모드 (Production / Development)
#   Production → API 키 인증 활성화, INFO 로깅 | Development → 인증 비활성화, DEBUG 로깅
APP_ENV=Development

# LOG_KEEPALIVE: 헬스체크 엔드포인트 (/health/live, /health/ready) 로그 출력 여부
#   True → 로그 출력 | False → 로그 억제
LOG_KEEPALIVE=True

# BACKEND_API_KEY: 프론트엔드가 x-api-key 헤더로 전송하는 공유 비밀키
#   APP_ENV=Production일 때 필수이며, /api/auth/** 및 /api/mcp/** 를 제외한
#   보호된 /api/** 요청은 이 값이 없으면 503으로 거부됩니다
BACKEND_API_KEY=

# JWT_SECRET: JWT 토큰 서명에 사용되는 HMAC 비밀키
#   Production 환경에서는 반드시 강력한 랜덤 값으로 변경하세요.
JWT_SECRET=change-me-in-production

# JWT_EXPIRY_HOURS: 발급한 JWT의 만료 시간(시간 단위)
JWT_EXPIRY_HOURS=24

# === Azure AI Foundry / OpenAI 프로젝트 ===

# AZURE_AI_PROJECT_ENDPOINT: Azure AI Projects 리소스의 전체 URL
#   형식: https://<resource>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT="https://kuko.services.ai.azure.com/api/projects/chat-project"

# AZURE_AI_AGENT_NAME: Foundry에서 생성/조회할 에이전트의 표시 이름
AZURE_AI_AGENT_NAME="chat-portal-agent"

# AZURE_AI_MODEL: 채팅 완성에 사용할 LLM 배포 이름
AZURE_AI_MODEL="gpt-5.4"

# === Azure AI 에이전트 동작 ===

# AZURE_AI_AGENT_INSTRUCTIONS: 에이전트에 주입되는 시스템 프롬프트
#   에이전트의 역할, 페르소나 및 응답 형식을 정의합니다
AZURE_AI_AGENT_INSTRUCTIONS="당신은 공장의 공정을 이상 징후를 감지하고 진단하고 조치를 권고하는 Agent입니다. 최대한 정확하게 진단에 대한 판단 근거를 제시를 하고, 예상되는 원인에 대한 판단 근거도 제시를 해야하고, 필요한 조치를 제안하며, 최선책과 차선책을 제시를 해야합니다. 보고는 timeline별로 방생된 상황을 우선 정의를 해야합니다."

# === Azure Entra ID (서비스 주체) ===

# AZURE_CLIENT_ID: Entra ID 서비스 주체의 애플리케이션 (클라이언트) ID
AZURE_CLIENT_ID=""

# AZURE_CLIENT_SECRET: 서비스 주체의 클라이언트 비밀 값
AZURE_CLIENT_SECRET=""

# AZURE_TENANT_ID: 서비스 주체가 등록된 디렉터리 (테넌트) ID
AZURE_TENANT_ID=""

# === Bing 그라운딩 검색 ===

# BING_GROUNDING_CONNECTION_NAME: Bing 그라운딩 검색을 위한 Azure AI Project 연결 이름
#   에이전트가 실시간 웹 데이터로 응답을 보강할 수 있도록 합니다
BING_GROUNDING_CONNECTION_NAME=""

# BROWSER_AUTOMATION_PROJECT_CONNECTION_ID: 브라우저 자동화 도구용 선택적 Foundry 연결 ID
BROWSER_AUTOMATION_PROJECT_CONNECTION_ID=""

# === Azure Speech 서비스 ===

# AZURE_SPEECH_ENDPOINT: Azure Cognitive Services 음성 엔드포인트 URL
#   형식: https://<resource>.cognitiveservices.azure.com/
AZURE_SPEECH_ENDPOINT=""

# AZURE_SPEECH_REGION: Azure Speech 리소스가 배포된 리전 코드
#   예: eastus2, koreacentral, westus3
AZURE_SPEECH_REGION=eastus2

# AZURE_SPEECH_LANGUAGE: 음성-텍스트 인식의 기본 BCP-47 로케일
#   예: ko-KR, en-US, ja-JP
AZURE_SPEECH_LANGUAGE="ko-KR"

# === GenAI 텔레메트리 트레이싱 ===

# AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING: GenAI 트레이싱 활성화 여부
#   true → LLM 호출에 대한 OpenTelemetry 스팬을 자동 생성합니다
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true

# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT: 트레이스에 메시지 내용 포함 여부
#   프로덕션에서는 개인정보 보호를 위해 false로 설정 권장
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# === 런타임 / 네트워킹 ===

# REQUEST_TIMEOUT_SECONDS: 아웃바운드 HTTP 요청의 전역 타임아웃 (초 단위)
#   config.py 기본값은 60초이며, 복잡한 도구 호출이 많은 경우 더 크게 조정할 수 있습니다
REQUEST_TIMEOUT_SECONDS=60

# BACKEND_PUBLIC_URL: Azure Container Apps에서 이 백엔드의 공개 기본 URL
#   Azure Speech 배치 작업의 오디오 다운로드에 필요합니다
# BACKEND_PUBLIC_URL=https://your-backend.azurecontainerapps.io

# === MySQL 연결 설정 ===

# MYSQL_HOST: Azure MySQL 유연한 서버의 호스트 이름
#   형식: <server-name>.mysql.database.azure.com
MYSQL_HOST=""

# MYSQL_PORT: MySQL 연결을 위한 TCP 포트 (기본값: 3306)
MYSQL_PORT=3306

# MYSQL_DB: 대상 데이터베이스 이름
MYSQL_DB=chatdb

# MYSQL_USER: 데이터베이스 로그인 사용자 이름
MYSQL_USER=

# MYSQL_PASSWORD: 데이터베이스 로그인 비밀번호
MYSQL_PASSWORD=

# MYSQL_SSL_MODE: MySQL 연결의 TLS 모드
#   값: required | preferred | disabled
#   Azure MySQL은 기본적으로 SSL을 강제합니다
MYSQL_SSL_MODE=required

# === MySQL 연결 튜닝 (선택사항) ===

# MYSQL_POOL_SIZE: SQLAlchemy 풀의 최대 영구 연결 수
MYSQL_POOL_SIZE=5

# MYSQL_CHARSET: PyMySQL 연결 문자열의 문자 집합 (utf8mb4 = 전체 유니코드 지원)
MYSQL_CHARSET=utf8mb4

# MYSQL_CONNECT_TIMEOUT: 새 연결 시도의 타임아웃 (초 단위)
MYSQL_CONNECT_TIMEOUT=10
