properties:
  configuration:
    secrets:
      - name: registry-password
        value: {{ registry_password }}
    registries:
      - server: {{ registry_name }}.azurecr.io
        username: {{ registry_name }}
        passwordSecretRef: registry-password
  template:
    containers:
      - name: {{ container_app_name }}
        image: {{ registry_name }}.azurecr.io/{{ image_name }}:{{ image_tag }}
        resources:
          cpu: {{ container_app_cpu }}
          memory: {{ container_app_memory }}
        probes:
          - type: Liveness
            httpGet:
              path: /health
              port: {{ container_app_port }}
              scheme: HTTP
            initialDelaySeconds: 2
            periodSeconds: 10
          - type: Readiness
            httpGet:
              path: /health
              port: {{ container_app_port }}
              scheme: HTTP
            initialDelaySeconds: 2
            periodSeconds: 10
    scale:
      minReplicas: 1
      maxReplicas: 1
      rules:
        - name: http-scaler
          http:
            metadata:
              concurrentRequests: "20"
