# ============================================================================
# 프론트엔드 환경 구성
# ============================================================================
# 이 파일은 AI 채팅 포털의 Next.js 프론트엔드를 구성합니다.
# Next.js 빌드 및 런타임 시 자동으로 로드됩니다.
#
# 보안: 이 파일에는 비밀 정보가 포함되어 있습니다. 버전 관리에 절대 커밋하지 마세요.
#           공개 템플릿은 .env.example을 사용하세요.
# ============================================================================

# ── 애플리케이션 URL 설정 ──────────────────────────────────────────────────

# APP_URL: 프론트엔드 애플리케이션의 공개 기본 URL.
#   현재 코드에서 직접 참조하지는 않지만, 외부 연동/운영 문서에서 사용할 수 있도록 유지합니다.
APP_URL=https://lgit-chat-frontend.mangofield-57a3b9f0.koreacentral.azurecontainerapps.io

# ── 백엔드 연결 설정 ──────────────────────────────────────────────────────

# NEXT_PUBLIC_BACKEND_URL: 백엔드 API 서버의 공개 기본 URL.
#   NEXT_PUBLIC_ 접두사로 인해 클라이언트(브라우저) 측 코드에서도 접근 가능합니다.
#   프론트엔드의 모든 API 호출이 이 URL을 기반으로 백엔드에 요청됩니다.
#   사용처: 채팅, 인증, 관리자 페이지 등 모든 API 호출
NEXT_PUBLIC_BACKEND_URL=https://lgit-chat-backend.mangofield-57a3b9f0.koreacentral.azurecontainerapps.io

# ── API 인증 키 ───────────────────────────────────────────────────────────

# NEXT_PUBLIC_BACKEND_API_KEY: 클라이언트 측에서 백엔드 API 호출 시 사용하는 API 키.
#   NEXT_PUBLIC_ 접두사로 브라우저에 노출되므로, 공개되어도 안전한 범위의 키여야 합니다.
#   백엔드의 x-api-key 헤더 인증과 매칭되어야 합니다.
#   사용처: 클라이언트 측 fetch 요청의 x-api-key 헤더
NEXT_PUBLIC_BACKEND_API_KEY=00MS6tR9Lln/RrOQrBMDrWBzBAh9lO8rX7NuvcC6VZ5n0L5t

# BACKEND_API_KEY: 서버 사이드(SSR)에서 백엔드 API 호출 시 사용하는 API 키.
#   NEXT_PUBLIC_ 접두사가 없어 서버 측에서만 접근 가능하며, 브라우저에 노출되지 않습니다.
#   서버 사이드 렌더링 또는 API 라우트에서 백엔드를 호출할 때 사용됩니다.
#   사용처: Next.js 서버 컴포넌트 및 API 라우트의 x-api-key 헤더
BACKEND_API_KEY=00MS6tR9Lln/RrOQrBMDrWBzBAh9lO8rX7NuvcC6VZ5n0L5t
